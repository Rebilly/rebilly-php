<?php
{{>file-header}}
declare(strict_types=1);

namespace {{fqn model.namespace}};

class {{model.className}}Factory
{
    public static function from(array $data = [], array $metadata = []): {{model.className}}
    {
        if ($data['isTrialOnly'] ?? false) {
            return {{model.className}}TrialOnlyPlan::from($data, $metadata);
        }
        if (isset($data['recurringInterval'])) {
            return {{model.className}}SubscriptionPlan::from($data, $metadata);
        }

        return {{model.className}}OneTimeSalePlan::from($data, $metadata);
    }
}
